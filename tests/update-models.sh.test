#!/usr/bin/env bash
#
# Tests for update-models.sh
# Run with: bash tests/update-models.sh.test

set -euo pipefail

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly TEST_DIR="$SCRIPT_DIR"
readonly PROJECT_DIR="$(dirname "$TEST_DIR")"

# Colors
readonly GREEN='\033[0;32m'
readonly RED='\033[0;31m'
readonly NC='\033[0m'

passed=0
failed=0

assert() {
  local expected="$1"
  local result="$2"
  local test_name="$3"

  if [[ "$result" == "$expected" ]]; then
    echo -e "${GREEN}[PASS]${NC} $test_name"
    passed=$((passed + 1))
  else
    echo -e "${RED}[FAIL]${NC} $test_name"
    echo "  Expected: '$expected'"
    echo "  Got: '$result'"
    failed=$((failed + 1))
  fi
}

# Source the script to test individual functions
source "$PROJECT_DIR/update-models.sh" 2>/dev/null || true
init_model_caps

echo "=========================================="
echo "Running update-models.sh tests"
echo "=========================================="
echo ""

# Test get_model_prefix functions directly
echo "Testing get_model_prefix..."

result=$(get_model_prefix "nvidia" "deepseek/test")
assert "nvidia_nim/deepseek/test" "$result" "nvidia prefix"

result=$(get_model_prefix "openrouter" "r1")
assert "open_router/r1" "$result" "openrouter prefix"

result=$(get_model_prefix "other" "x")
assert "other/x" "$result" "unknown prefix"

# Test get_cap_key
result=$(get_cap_key "nvidia" "deepseek-v3")
assert "nvidia/deepseek-v3" "$result" "get_cap_key"

echo ""
echo "Testing parse_model_json contract..."
json='[
  {"modelId":"moonshotai/kimi-k2.5","provider":"nvidia","tier":"S","swe":70.9,"status":"up","verdict":"Normal","avgMs":210,"stability":88,"toolCallProbeStatus":"pass","toolCallOk":true},
  {"provider":"openrouter","modelId":"qwen/qwen3.6-plus:free","status":"up","swe":65.0,"tier":"A","verdict":"Unknown","avgMs":null,"stability":null,"degraded":true,"toolCallProbeStatus":"unknown","toolCallOk":null}
]'
parse_model_json "$json" >/dev/null
count="${#MODEL_DATA_PROVIDER[@]}"
assert "2" "$count" "parse_model_json count"
assert "nvidia" "${MODEL_DATA_PROVIDER[0]}" "parse provider 0"
assert "moonshotai/kimi-k2.5" "${MODEL_DATA_MODELID[0]}" "parse modelId 0"
assert "pass" "${MODEL_DATA_TOOLCALL_STATUS[0]}" "parse tool status pass"
assert "true" "${MODEL_DATA_TOOLCALLOK[0]}" "parse tool ok true"
assert "0" "${MODEL_DATA_STABILITY[1]}" "null stability default"
assert "9999" "${MODEL_DATA_AVGMS[1]}" "null avg default"
assert "true" "$DEGRADED_MODE" "degraded mode detection"

echo ""
echo "Testing tool_call_ok fallback semantics..."
result=1
tool_call_ok "nvidia" "moonshotai/kimi-k2.5" 0 || result=0
assert "1" "$result" "tool_call_ok pass from probe"

MODEL_DATA_TOOLCALL_STATUS[0]="unknown"
MODEL_DATA_TOOLCALLOK[0]="null"
result=1
tool_call_ok "nvidia" "moonshotai/kimi-k2.5" 0 || result=0
assert "1" "$result" "tool_call_ok unknown falls back to registry true"

MODEL_DATA_TOOLCALL_STATUS[0]="unknown"
MODEL_DATA_TOOLCALLOK[0]="null"
result=1
tool_call_ok "openrouter" "qwen/qwen3.6-plus:free" 0 || result=0
assert "0" "$result" "tool_call_ok unknown falls back to registry false"

echo ""
echo "Testing corrected openrouter thinking registry key..."
result=0
is_thinking_model "openrouter" "qwen/qwen3.6-plus:free" && result=1
assert "1" "$result" "openrouter qwen thinking key"

echo ""
echo "=========================================="
echo "Results: $passed passed, $failed failed"
echo "=========================================="

[[ $failed -eq 0 ]] && exit 0 || exit 1
